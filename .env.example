# Copy this to .env and adjust if needed
# NO API keys required — everything is free and local!

OLLAMA_BASE_URL=http://localhost:11434

# Options: llama3, mistral, phi3, gemma2
LLM_MODEL=llama3

# Free embedding model — run: ollama pull nomic-embed-text
EMBEDDING_MODEL=nomic-embed-text

CHROMA_PERSIST_DIR=./chroma_db
CHROMA_COLLECTION_NAME=medical_book

CHUNK_SIZE=800
CHUNK_OVERLAP=150
RETRIEVAL_TOP_K=5
